<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Syrine BEN ANAYA - Software Engineer</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" crossorigin="anonymous" />
    <!-- Google Fonts (Fraunces + Inter + JetBrains Mono) -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700;9..144,800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
        /* ====================================================
           VARIABLES (thème clair / sombre)
           ==================================================== */
        :root {
            --bg-color: #f8f6f2;
            --bg-light: #f0ede8;
            --text-primary: #241f2b;
            --text-secondary: #5a5460;
            --card-bg: #ffffff;
            --border-light: rgba(36, 31, 43, 0.08);
            --shadow: 0 8px 24px rgba(36, 31, 43, 0.08);
            --shadow-lg: 0 24px 60px rgba(36, 31, 43, 0.14);
            --accent-color: #7c5aa6;
            --mint: #4fb8a3;
            --gold: #d9a24b;
            --accent-gradient: linear-gradient(135deg, #7c5aa6, #b98fd1);
            --navbar-bg: rgba(248, 246, 242, 0.82);
            --footer-border: #e0dcd6;
            --footer-bg: #201b28;
            --code-bg: #1c1726;
            --code-border: #352b47;
            --code-text: #e9e4f2;
            --font-display: 'Fraunces', serif;
            --font-body: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
            --lang-bg: #eae6f0;
            --lang-text: #241f2b;
        }

        [data-theme="dark"] {
            --bg-color: #12101a;
            --bg-light: #191521;
            --text-primary: #f1eef7;
            --text-secondary: #b3adc0;
            --card-bg: #201b2c;
            --border-light: rgba(255, 255, 255, 0.08);
            --shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
            --shadow-lg: 0 24px 60px rgba(0, 0, 0, 0.55);
            --accent-color: #b494d9;
            --mint: #6bcdb8;
            --gold: #e3b465;
            --accent-gradient: linear-gradient(135deg, #9a72c6, #d1aee6);
            --navbar-bg: rgba(18, 16, 26, 0.86);
            --footer-border: #322b3d;
            --footer-bg: #0d0b13;
            --code-bg: #0f0c17;
            --code-border: #2c2438;
            --code-text: #e9e4f2;
            --lang-bg: #2c2438;
            --lang-text: #f1eef7;
        }

        /* ====================================================
           BASE
           ==================================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        @media (prefers-reduced-motion: reduce) {
            html {
                scroll-behavior: auto;
            }
            *,
            *::before,
            *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
                scroll-behavior: auto !important;
            }
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-color);
            color: var(--text-primary);
            transition: background-color 0.3s ease, color 0.3s ease;
            overflow-x: hidden;
        }

        h1,
        h2,
        h3,
        h4,
        h5 {
            font-family: var(--font-display);
            letter-spacing: -0.01em;
        }

        .eyebrow {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--accent-color);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }
        .eyebrow .dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--mint);
            box-shadow: 0 0 0 4px rgba(79, 184, 163, 0.18);
            animation: pulseDot 2.2s ease-in-out infinite;
        }
        @keyframes pulseDot {
            0%,
            100% {
                transform: scale(1);
                box-shadow: 0 0 0 4px rgba(79, 184, 163, 0.18);
            }
            50% {
                transform: scale(1.25);
                box-shadow: 0 0 0 7px rgba(79, 184, 163, 0.1);
            }
        }

        .text-muted {
            color: var(--text-secondary) !important;
        }
        .bg-light-dark {
            background-color: var(--bg-light);
        }

        section {
            position: relative;
        }
        .section-kicker {
            font-family: var(--font-mono);
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--accent-color);
            display: block;
            text-align: center;
            margin-bottom: 0.6rem;
        }

        /* ====================================================
           REVEAL ANIMATIONS
           ==================================================== */
        .reveal {
            opacity: 0;
            transform: translateY(48px);
            transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .reveal-scale {
            opacity: 0;
            transform: scale(0.94);
            transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .reveal-scale.visible {
            opacity: 1;
            transform: scale(1);
        }
        [data-stagger] .reveal:nth-child(1) {
            transition-delay: 0.05s;
        }
        [data-stagger] .reveal:nth-child(2) {
            transition-delay: 0.15s;
        }
        [data-stagger] .reveal:nth-child(3) {
            transition-delay: 0.25s;
        }
        [data-stagger] .reveal:nth-child(4) {
            transition-delay: 0.35s;
        }

        /* ====================================================
           NAVBAR
           ==================================================== */
        .glass-navbar {
            background: var(--navbar-bg) !important;
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border-light);
            transition: padding 0.3s ease, box-shadow 0.3s ease;
        }
        .navbar-shrink {
            padding-top: 0.25rem !important;
            padding-bottom: 0.25rem !important;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }
        .navbar-brand {
            font-family: var(--font-display);
            font-weight: 700;
            color: var(--text-primary) !important;
        }
        .navbar-nav .nav-link {
            color: var(--text-secondary);
            font-weight: 500;
            transition: color 0.3s ease;
            position: relative;
        }
        .navbar-nav .nav-link::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: -2px;
            width: 0;
            height: 2px;
            background: var(--accent-gradient);
            transition: width 0.3s ease;
        }
        .navbar-nav .nav-link:hover::after,
        .navbar-nav .nav-link.active::after {
            width: 100%;
        }
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link.active {
            color: var(--text-primary);
        }

        /* ====================================================
           HERO
           ==================================================== */
        .hero-section {
            min-height: 100vh;
            position: relative;
            margin-top: -76px;
            padding-top: 120px;
            padding-bottom: 60px;
            display: flex;
            align-items: center;
            overflow: hidden;
        }
        .hero-spotlight {
            position: absolute;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background: radial-gradient(600px circle at var(--mx, 50%) var(--my, 30%), rgba(124, 90, 166, 0.10), transparent 70%);
            transition: background 0.2s ease;
        }
        .hero-bg-glow {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
            z-index: 0;
        }
        .glow-orb {
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            filter: blur(120px);
            opacity: 0.25;
            animation: floatGlow 12s ease-in-out infinite alternate;
        }
        .glow-orb-1 {
            background: #7c5aa6;
            top: -10%;
            left: -8%;
        }
        .glow-orb-2 {
            background: #4fb8a3;
            bottom: -12%;
            right: -8%;
            animation-delay: 4s;
            opacity: 0.18;
        }
        @keyframes floatGlow {
            0% {
                transform: translate(0, 0) scale(1);
            }
            100% {
                transform: translate(60px, 40px) scale(1.2);
            }
        }

        .hero-grid {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            gap: 3.5rem;
            align-items: center;
        }
        @media (max-width: 991px) {
            .hero-grid {
                grid-template-columns: 1fr;
                gap: 2.5rem;
            }
        }

        .hero-name {
            font-size: clamp(2.4rem, 5vw, 3.6rem);
            font-weight: 700;
            line-height: 1.05;
            margin: 0.5rem 0 0.7rem;
        }
        .hero-name .accent-word {
            background: var(--accent-gradient);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 6s ease-in-out infinite;
        }
        @keyframes shimmer {
            0% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
            100% {
                background-position: 0% 50%;
            }
        }

        .hero-role {
            font-family: var(--font-mono);
            font-size: clamp(1.05rem, 2vw, 1.3rem);
            color: var(--text-secondary);
            min-height: 1.8em;
            display: flex;
            align-items: center;
            gap: 0.15rem;
            margin-bottom: 1.4rem;
        }
        .hero-role .type-cursor {
            display: inline-block;
            width: 2px;
            height: 1.1em;
            background: var(--mint);
            animation: blinkCursor 0.9s step-end infinite;
            margin-left: 2px;
        }
        @keyframes blinkCursor {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0;
            }
        }

        .hero-pitch {
            max-width: 540px;
            font-size: 1.05rem;
            line-height: 1.7;
            color: var(--text-secondary);
            margin-bottom: 1.8rem;
        }

        .hero-cta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.9rem;
            margin-bottom: 1.9rem;
        }
        .btn-hero-primary {
            background: var(--accent-gradient);
            color: #fff;
            border: none;
            padding: 0.75rem 1.6rem;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
            box-shadow: 0 10px 24px rgba(124, 90, 166, 0.28);
        }
        .btn-hero-primary:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 34px rgba(124, 90, 166, 0.38);
            color: #fff;
        }
        .btn-hero-ghost {
            border: 1.5px solid var(--border-light);
            color: var(--text-primary);
            padding: 0.75rem 1.6rem;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            background: transparent;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.35s ease;
        }
        .btn-hero-ghost:hover {
            border-color: var(--accent-color);
            color: var(--accent-color);
            transform: translateY(-4px);
        }

        .hero-socials {
            display: flex;
            gap: 0.8rem;
            margin-bottom: 2.4rem;
        }
        .icon-btn {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            border: 1.5px solid var(--border-light);
            text-decoration: none;
            color: var(--text-primary);
            background: transparent;
        }
        .icon-btn:hover {
            background: var(--accent-gradient);
            border-color: transparent;
            transform: translateY(-6px) rotate(6deg) scale(1.08);
            box-shadow: 0 10px 20px rgba(124, 90, 166, 0.28);
            color: #fff;
        }

        .hero-stats {
            display: flex;
            gap: 2.2rem;
            flex-wrap: wrap;
        }
        .hero-stat-num {
            font-family: var(--font-display);
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1;
        }
        .hero-stat-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 0.3rem;
            letter-spacing: 0.02em;
        }

        /* ---- code window (signature element) ---- */
        .code-window-wrap {
            position: relative;
        }
        .code-badge {
            position: absolute;
            z-index: 2;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            background: var(--card-bg);
            border: 1px solid var(--border-light);
            border-radius: 40px;
            padding: 0.4rem 0.85rem;
            font-size: 0.78rem;
            font-weight: 600;
            box-shadow: var(--shadow);
            animation: floatBadge 5s ease-in-out infinite;
        }
        .code-badge i {
            font-size: 0.85rem;
        }
        .badge-1 {
            top: -18px;
            left: -10px;
            animation-delay: 0s;
            color: #61DAFB;
        }
        .badge-2 {
            bottom: 10%;
            right: -18px;
            animation-delay: 1.2s;
            color: #E0234E;
        }
        .badge-3 {
            bottom: -20px;
            left: 18%;
            animation-delay: 2.4s;
            color: #4DB33D;
        }
        @keyframes floatBadge {
            0%,
            100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
        }

        .code-window {
            background: var(--code-bg);
            border: 1px solid var(--code-border);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            overflow: hidden;
            font-family: var(--font-mono);
            transform: perspective(1200px) rotateY(-6deg) rotateX(2deg);
            transition: transform 0.5s ease;
        }
        .code-window:hover {
            transform: perspective(1200px) rotateY(0deg) rotateX(0deg);
        }
        .code-titlebar {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.7rem 1rem;
            border-bottom: 1px solid var(--code-border);
        }
        .code-dot {
            width: 11px;
            height: 11px;
            border-radius: 50%;
        }
        .code-dot.red {
            background: #ff5f57;
        }
        .code-dot.yellow {
            background: #febc2e;
        }
        .code-dot.green {
            background: #28c840;
        }
        .code-filename {
            margin-left: 0.6rem;
            font-size: 0.78rem;
            color: #9d94b3;
        }
        .code-body {
            padding: 1.3rem 1.4rem;
            font-size: 0.86rem;
            line-height: 1.85;
            min-height: 260px;
            color: var(--code-text);
        }
        .code-line {
            white-space: pre;
            opacity: 0;
            animation: codeLineIn 0.4s ease forwards;
        }
        @keyframes codeLineIn {
            from {
                opacity: 0;
                transform: translateY(4px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .tok-kw {
            color: #c792ea;
        }
        .tok-str {
            color: #9ddc88;
        }
        .tok-fn {
            color: #82aaff;
        }
        .tok-com {
            color: #6c6485;
        }
        .tok-var {
            color: #f78c6c;
        }
        .tok-punc {
            color: #9d94b3;
        }
        .code-cursor {
            display: inline-block;
            width: 7px;
            height: 1em;
            background: var(--mint);
            vertical-align: middle;
            animation: blinkCursor 0.9s step-end infinite;
        }

        .scroll-cue {
            position: absolute;
            bottom: 18px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.4rem;
            color: var(--text-secondary);
            font-family: var(--font-mono);
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }
        .scroll-cue i {
            animation: bounceCue 1.8s ease-in-out infinite;
        }
        @keyframes bounceCue {
            0%,
            100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(8px);
            }
        }

        /* ====================================================
           ABOUT — ENHANCED
           ==================================================== */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2.5rem;
        }
        @media (max-width: 768px) {
            .about-grid {
                grid-template-columns: 1fr;
            }
        }

        .about-card {
            background: var(--card-bg);
            border: 1px solid var(--border-light);
            border-radius: 18px;
            padding: 2rem 1.8rem;
            box-shadow: var(--shadow);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            height: 100%;
        }
        .about-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
        }
        .about-card .card-icon {
            font-size: 2rem;
            color: var(--accent-color);
            margin-bottom: 0.75rem;
            display: inline-block;
        }
        .about-card h4 {
            font-weight: 700;
            margin-bottom: 1.2rem;
            font-size: 1.2rem;
            color: var(--text-primary);
        }
        .about-card p,
        .about-card li {
            color: var(--text-secondary);
            font-size: 0.98rem;
            line-height: 1.6;
        }
        .about-card ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .about-card ul li {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.35rem 0;
            border-bottom: 1px solid var(--border-light);
        }
        .about-card ul li:last-child {
            border-bottom: none;
        }
        .about-card ul li .lang-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
            display: inline-block;
        }
        .lang-dot.c2 {
            background: #28a745;
        }
        .lang-dot.c1 {
            background: #17a2b8;
        }
        .lang-dot.b2 {
            background: #ffc107;
        }
        .lang-level {
            font-family: var(--font-mono);
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--accent-color);
            background: var(--lang-bg);
            padding: 0.1rem 0.6rem;
            border-radius: 20px;
            margin-left: auto;
            white-space: nowrap;
        }
        [data-theme="dark"] .lang-level {
            background: #2c2438;
            color: #b494d9;
        }
        .about-bio {
            max-width: 720px;
            margin: 0 auto 0.5rem;
            font-size: 1.05rem;
            line-height: 1.7;
            color: var(--text-secondary);
            text-align: center;
        }

        /* --- Education items inside about-card --- */
        .edu-item {
            padding: 0.5rem 0;
            border-bottom: 1px solid var(--border-light);
        }
        .edu-item:last-child {
            border-bottom: none;
        }
        .edu-item .edu-title {
            font-weight: 600;
            color: var(--text-primary);
            font-size: 1rem;
        }
        .edu-item .edu-institution {
            font-size: 0.92rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .edu-item .edu-institution i {
            color: var(--accent-color);
            font-size: 0.85rem;
            width: 1.1rem;
        }
        .edu-item .edu-year {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            color: var(--text-secondary);
            background: var(--lang-bg);
            padding: 0.05rem 0.7rem;
            border-radius: 20px;
            display: inline-block;
            margin-top: 0.15rem;
        }
        [data-theme="dark"] .edu-item .edu-year {
            background: #2c2438;
            color: #b3adc0;
        }
        .edu-item .edu-badge {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--accent-color);
            background: var(--lang-bg);
            padding: 0.05rem 0.65rem;
            border-radius: 20px;
            display: inline-block;
            margin-left: 0.5rem;
        }
        [data-theme="dark"] .edu-item .edu-badge {
            background: #2c2438;
        }

        /* ====================================================
           SKILLS
           ==================================================== */
        .skill-category {
            margin-bottom: 2.6rem;
        }
        .skill-category h4 {
            color: var(--text-primary);
            font-weight: 600;
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 1.15rem;
        }
        .skill-item {
            margin-bottom: 1.3rem;
        }
        .skill-item .skill-label {
            display: flex;
            justify-content: space-between;
            font-weight: 500;
            margin-bottom: 0.4rem;
            font-size: 0.95rem;
        }
        .skill-item .skill-percent {
            font-family: var(--font-mono);
            color: var(--accent-color);
            font-weight: 600;
        }
        .progress {
            background: var(--border-light);
            border-radius: 20px;
            height: 7px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            border-radius: 20px;
            background: var(--accent-gradient);
            width: 0;
            transition: width 1.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* ====================================================
           PROJECTS
           ==================================================== */
        .project-card {
            background: var(--card-bg) !important;
            transition: transform 0.15s ease, box-shadow 0.4s ease;
            overflow: hidden;
            border: 1px solid var(--border-light) !important;
            box-shadow: var(--shadow);
            transform-style: preserve-3d;
        }
        .project-card:hover {
            box-shadow: var(--shadow-lg);
        }
        .project-card img {
            height: 200px;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .project-card:hover img {
            transform: scale(1.05);
        }
        .btn-gradient {
            background: var(--accent-gradient);
            border: none;
            transition: opacity 0.3s ease, transform 0.3s ease;
            color: #fff;
        }
        .btn-gradient:hover {
            opacity: 0.92;
            color: #fff;
            transform: translateY(-2px);
        }

        .tech-stack {
            display: flex;
            flex-wrap: wrap;
            gap: 0.3rem 0.4rem;
        }
        .tech-tag {
            background: #e8e4e0;
            border: 1px solid #d0ccc6;
            border-radius: 20px;
            padding: 0.15rem 0.7rem;
            font-size: 0.7rem;
            font-weight: 500;
            color: #2c2a2a;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            transition: 0.3s;
            white-space: nowrap;
        }
        .tech-tag i {
            font-size: 0.75rem;
            color: var(--accent-color);
        }
        .tech-tag:hover {
            border-color: var(--accent-color);
            background: #f0ede8;
            transform: translateY(-1px);
        }
        [data-theme="dark"] .tech-tag {
            background: #2c2438;
            border-color: #443a56;
            color: #f0edf2;
        }
        [data-theme="dark"] .tech-tag:hover {
            background: #382e49;
            border-color: var(--accent-color);
        }

        /* ====================================================
           CONTACT
           ==================================================== */
        .contact-link {
            text-decoration: none;
        }
        .contact-item {
            background: var(--card-bg);
            border: 1px solid var(--border-light);
            padding: 1.8rem;
            border-radius: 16px;
            min-width: 180px;
            transition: all 0.3s ease;
            box-shadow: var(--shadow);
        }
        .contact-item:hover {
            transform: translateY(-6px);
            border-color: var(--accent-color);
            box-shadow: 0 12px 28px rgba(124, 90, 166, 0.16);
        }
        .contact-item i {
            color: var(--accent-color);
        }

        /* ====================================================
           THEME TOGGLE
           ==================================================== */
        .theme-toggle {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            font-size: 1.3rem;
            cursor: pointer;
            padding: 0.4rem 0.6rem;
            border-radius: 30px;
            transition: 0.3s;
        }
        .theme-toggle:hover {
            color: var(--text-primary);
            background: var(--border-light);
        }

        /* ====================================================
           FOOTER
           ==================================================== */
        .footer-custom {
            background-color: var(--footer-bg);
            border-color: var(--footer-border) !important;
            color: #f0edf2;
        }

        /* ====================================================
           RTL
           ==================================================== */
        html[dir="rtl"] {
            text-align: right;
        }
        html[dir="rtl"] .ms-auto {
            margin-left: 0 !important;
            margin-right: auto !important;
        }
        html[dir="rtl"] .dropdown-menu-end {
            right: auto;
            left: 0;
